MONGODB_URI=mongodb://127.0.0.1:27017/foodie
JWT_SECRET=change-this-to-a-long-random-string-in-production
PORT=5000

# Razorpay (https://dashboard.razorpay.com — use Test Mode keys for development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# Cart totals use $ in the app; converted to INR for Razorpay (1 USD ≈ 83 INR by default)
USD_TO_INR_RATE=83
